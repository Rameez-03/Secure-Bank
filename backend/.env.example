# Copy this EXACTLY - these are development-only keys
# .env.example - Safe to commit
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/secure-banking

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Secrets - GENERATE YOUR OWN
JWT_ACCESS_SECRET=CHANGE_ME_run_node_crypto_randomBytes_64_hex
JWT_REFRESH_SECRET=CHANGE_ME_run_node_crypto_randomBytes_64_hex

# Encryption - GENERATE YOUR OWN
ENCRYPTION_KEY=CHANGE_ME_must_be_exactly_64_hex_characters_32bytes

# Plaid
USE_MOCK_PLAID=true
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Features
ENABLE_2FA=false
ENABLE_EMAIL_VERIFICATION=false
ENABLE_AUDIT_LOGGING=true