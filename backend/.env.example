# Copy this EXACTLY - these are development-only keys
# .env.example - Safe to commit
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/secure-banking

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Secrets - GENERATE YOUR OWN
JWT_SECRET=CHANGE_ME_run_node_crypto_randomBytes_64_hex
JWT_REFRESH_SECRET=CHANGE_ME_run_node_crypto_randomBytes_64_hex

# Encryption - GENERATE YOUR OWN
ENCRYPTION_KEY=CHANGE_ME_must_be_exactly_64_hex_characters_32bytes

# Plaid
USE_MOCK_PLAID=true
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# Frontend
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Email (nodemailer) — required for forgot-password flow
# Leave blank in development to log reset links to the console instead
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM="SecureBank" <noreply@yourdomain.com>

# Features
ENABLE_2FA=false
ENABLE_EMAIL_VERIFICATION=false
ENABLE_AUDIT_LOGGING=true